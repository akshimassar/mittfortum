# Copy this file to .env and fill in your account values.
# .env is used by live e2e tests and local debugging scripts.

# Enable live end-to-end tests (set to 1 to run tests/e2e/test_live_api.py)
FORTUM_E2E=0

# Fortum account credentials
FORTUM_USERNAME=your.email@example.com
FORTUM_PASSWORD=your-password

# Region for API endpoints: fi or se
FORTUM_REGION=fi
